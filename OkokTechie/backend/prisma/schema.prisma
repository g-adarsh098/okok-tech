datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Requirement {
  id        Int      @id @default(autoincrement())
  projectId String
  clientId  String
  details   String
  fullLog   String
  status    String   @default("NEW")
  createdAt DateTime @default(now())
}
